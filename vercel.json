{
  "version": 2,
  "cleanUrls": true,
  "redirects": [
    { "source": "/family-law", "destination": "/apps/family-law-settlement", "permanent": false },
    { "source": "/criminal", "destination": "/apps/criminal-guilty-plea", "permanent": false },
    { "source": "/bail", "destination": "/apps/bail-cheatsheet", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
